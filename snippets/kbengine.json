      "\t<Flags> CELL_PUBLIC </Flags>",
      "\t<Default> ${3:0} </Default>",
      "\t<DetailLevel> ${4|LOW,MEDIUM,HIGH,CRITICAL|} </DetailLevel>",
      "</${1:PropertyName}>$0"
    ]
  },
