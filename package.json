{
  "name": "kode",
  "displayName": "Kode - KBEngine Development Environment",
  "description": "Complete language support for KBEngine game server framework with syntax highlighting, IntelliSense, and more",
  "version": "0.1.0",
  "publisher": "cuihairu",
  "author": {
    "name": "cuihairu",
    "email": "cuihairu@gmail.com"
  },
  "license": "Apache-2.0",
  "icon": "resources/logo.png",
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "keywords": [
    "kbengine",
    "game-server",
    "mmo",
    "entity",
    "def",
    "python"
  ],
  "activationEvents": [
    "onLanguage:kbengine-def",
    "onCommand:kbengine.refreshExplorer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kbengine-def",
        "aliases": [
          "KBEngine Def",
          "kbengine-def",
          "def"
        ],
        "extensions": [
          ".def"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kbengine-def",
        "scopeName": "source.kbengine-def",
        "path": "./syntaxes/kbengine.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "kbengine-def",
        "path": "./snippets/kbengine.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kbengine-explorer",
          "title": "KBEngine Explorer",
          "icon": "resources/logo.png"
        }
      ]
    },
    "views": {
      "kbengine-explorer": [
        {
          "id": "kbengine.entityExplorer",
          "name": "Entities"
        },
        {
          "id": "kbengine.serverControl",
          "name": "Servers"
        }
      ]
    },
    "commands": [
      {
        "command": "kbengine.refreshExplorer",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "kbengine.server.start",
        "title": "Start Server",
        "icon": "$(play)"
      },
      {
        "command": "kbengine.server.stop",
        "title": "Stop Server",
        "icon": "$(stop)"
      },
      {
        "command": "kbengine.server.restart",
        "title": "Restart Server",
        "icon": "$(refresh)"
      },
      {
        "command": "kbengine.server.showLogs",
        "title": "Show Logs",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kbengine.refreshExplorer",
          "when": "view == kbengine.entityExplorer",
          "group": "navigation"
        },
        {
          "command": "kbengine.server.start",
          "when": "view == kbengine.serverControl",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "kbengine.server.start",
          "when": "view == kbengine.serverControl",
          "group": "inline"
        },
        {
          "command": "kbengine.server.stop",
          "when": "view == kbengine.serverControl",
          "group": "inline"
        },
        {
          "command": "kbengine.server.restart",
          "when": "view == kbengine.serverControl",
          "group": "inline"
        },
        {
          "command": "kbengine.server.showLogs",
          "when": "view == kbengine.serverControl",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "KBEngine",
      "properties": {
        "kbengine.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "启用 KBEngine 实时语法检查"
        },
        "kbengine.entityDefsPath": {
          "type": "string",
          "default": "scripts/entity_defs",
          "description": "实体定义文件的默认路径"
        },
        "kbengine.entitiesXmlPath": {
          "type": "string",
          "default": "scripts/entities.xml",
          "description": "entities.xml 文件的默认路径"
        },
        "kbengine.binPath": {
          "type": "string",
          "default": "${workspaceFolder}/../kbengine/kbe/bin",
          "description": "KBEngine 二进制文件路径，支持 ${workspaceFolder} 和 ${env:VAR}"
        },
        "kbengine.configPath": {
          "type": "string",
          "default": "${workspaceFolder}/server",
          "description": "KBEngine 配置文件路径"
        },
        "kbengine.autoStart": {
          "type": "array",
          "default": ["machine", "logger", "dbmgr"],
          "description": "自动启动的组件列表",
          "items": {
            "type": "string",
            "enum": ["machine", "logger", "dbmgr", "baseappmgr", "cellappmgr", "loginapp", "baseapp", "cellapp", "bots"]
          }
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cuihairu/kode.git"
  },
  "bugs": {
    "url": "https://github.com/cuihairu/kode/issues"
  },
  "homepage": "https://github.com/cuihairu/kode#readme",
  "scripts": {
    "vscode:prepublish": "echo 'skip prepublish'",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "pnpm run compile && vsce package --no-yarn",
    "publish": "vsce publish --no-yarn"
  },
  "devDependencies": {
    "@types/glob": "^7.1.3",
    "@types/mocha": "^8.2.2",
    "@types/node": "14.x",
    "@types/vscode": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^4.23.0",
    "@typescript-eslint/parser": "^4.23.0",
    "@vscode/test-electron": "^1.0.2",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^7.26.0",
    "glob": "^7.1.7",
    "mocha": "^8.4.0",
    "typescript": "^4.2.5"
  }
}
