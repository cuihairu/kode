{
  "name": "kode",
  "displayName": "Kode - KBEngine Development Environment",
  "description": "Complete language support for KBEngine game server framework with syntax highlighting, IntelliSense, and more",
  "version": "0.1.0",
  "publisher": "cuihairu",
  "author": {
    "name": "cuihairu",
    "email": "cuihairu@gmail.com"
  },
  "license": "Apache-2.0",
  "icon": "resources/logo.png",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "keywords": [
    "kbengine",
    "game-server",
    "mmo",
    "entity",
    "def",
    "python"
  ],
  "activationEvents": [
    "onLanguage:kbengine-def",
    "onCommand:kbengine.refreshExplorer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [{
      "id": "kbengine-def",
      "aliases": ["KBEngine Def", "kbengine-def", "def"],
      "extensions": [".def"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "kbengine-def",
      "scopeName": "source.kbengine-def",
      "path": "./syntaxes/kbengine.tmLanguage.json"
    }],
    "snippets": [{
      "language": "kbengine-def",
      "path": "./snippets/kbengine.json"
    }],
    "viewsContainers": {
      "activitybar": [{
        "id": "kbengine-explorer",
        "title": "KBEngine Explorer",
        "icon": "resources/logo.png"
      }]
    },
    "views": {
      "kbengine-explorer": [{
        "id": "kbengine.entityExplorer",
        "name": "Entities"
      }]
    },
    "commands": [{
      "command": "kbengine.refreshExplorer",
      "title": "Refresh",
      "icon": "$(refresh)"
    }],
    "menus": {
      "view/title": [{
        "command": "kbengine.refreshExplorer",
        "when": "view == kbengine.entityExplorer",
        "group": "navigation"
      }]
    },
    "configuration": {
      "title": "KBEngine",
      "properties": {
        "kbengine.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "启用 KBEngine 实时语法检查"
        },
        "kbengine.entityDefsPath": {
          "type": "string",
          "default": "scripts/entity_defs",
          "description": "实体定义文件的默认路径"
        },
        "kbengine.entitiesXmlPath": {
          "type": "string",
          "default": "scripts/entities.xml",
          "description": "entities.xml 文件的默认路径"
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cuihairu/kode.git"
  },
  "bugs": {
    "url": "https://github.com/cuihairu/kode/issues"
  },
  "homepage": "https://github.com/cuihairu/kode#readme",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/glob": "^7.1.3",
    "@types/mocha": "^8.2.2",
    "@types/node": "14.x",
    "@typescript-eslint/eslint-plugin": "^4.23.0",
    "@typescript-eslint/parser": "^4.23.0",
    "eslint": "^7.26.0",
    "glob": "^7.1.7",
    "mocha": "^8.4.0",
    "typescript": "^4.2.5",
    "@vscode/test-electron": "^1.0.2"
  }
}
