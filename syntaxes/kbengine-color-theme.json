{
  "name": "KBEngine Dark",
  "colors": {
    "editor.background": "#272822",
    "editor.foreground": "#F8F8F2",
    "activityBarBadge.background": "#66D9EF",
    "sideBarTitle.foreground": "#F8F8F2"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#75715E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": ["string.quoted.double.xml", "string.quoted.single.xml", "string.quoted.double.kbengine"],
      "settings": {
        "foreground": "#E6DB74"
      }
    },
    {
      "name": "KBEngine Section Tags",
      "scope": "entity.name.tag.section.kbengine",
      "settings": {
        "foreground": "#E6DB74",
        "fontStyle": "bold"
      }
    },
    {
      "name": "KBEngine Scalar Tags",
      "scope": [
        "entity.name.tag.scalar.type.kbengine",
        "entity.name.tag.scalar.arg.kbengine",
        "entity.name.tag.scalar.flags.kbengine",
        "entity.name.tag.scalar.detail-level.kbengine",
        "entity.name.tag.scalar.default.kbengine",
        "entity.name.tag.scalar.numeric.kbengine"
      ],
      "settings": {
        "foreground": "#66D9EF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "KBEngine Property And Method Tags",
      "scope": "entity.name.symbol.kbengine",
      "settings": {
        "foreground": "#A6E22E",
        "fontStyle": "bold"
      }
    },
    {
      "name": "KBEngine Integer Types",
      "scope": "support.type.primitive.integer.kbengine",
      "settings": {
        "foreground": "#66D9EF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "KBEngine Float Types",
      "scope": "support.type.primitive.float.kbengine",
      "settings": {
        "foreground": "#66D9EF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "KBEngine Boolean",
      "scope": "support.type.primitive.boolean.kbengine",
      "settings": {
        "foreground": "#F92672",
        "fontStyle": "bold"
      }
    },
    {
      "name": "KBEngine String",
      "scope": "support.type.primitive.string.kbengine",
      "settings": {
        "foreground": "#E6DB74",
        "fontStyle": "bold"
      }
    },
    {
      "name": "KBEngine Vector Types",
      "scope": "support.type.vector.kbengine",
      "settings": {
        "foreground": "#AE81FF",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "KBEngine Reference",
      "scope": "support.type.reference.kbengine",
      "settings": {
        "foreground": "#AE81FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "KBEngine Container Types",
      "scope": ["support.type.container.kbengine", "support.type.container.tag.kbengine"],
      "settings": {
        "foreground": "#AE81FF",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "KBEngine Python",
      "scope": "support.type.python.kbengine",
      "settings": {
        "foreground": "#A6E22E",
        "fontStyle": "bold"
      }
    },
    {
      "name": "KBEngine Flags",
      "scope": ["constant.language.flag.kbengine", "constant.other.flag.kbengine"],
      "settings": {
        "foreground": "#FD971F",
        "fontStyle": "bold"
      }
    },
    {
      "name": "KBEngine Detail Level",
      "scope": "support.constant.detail-level.kbengine",
      "settings": {
        "foreground": "#AE81FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "KBEngine Keywords",
      "scope": ["keyword.control.kbengine", "keyword.declaration.flag.kbengine"],
      "settings": {
        "foreground": "#F92672",
        "fontStyle": "bold"
      }
    },
    {
      "name": "KBEngine Entity Names",
      "scope": ["entity.name.function.xml", "entity.name.tag.localname.xml"],
      "settings": {
        "foreground": "#E6DB74",
        "fontStyle": "bold"
      }
    },
    {
      "name": "XML Tag Punctuation",
      "scope": ["punctuation.definition.tag.begin.xml", "punctuation.definition.tag.end.xml"],
      "settings": {
        "foreground": "#F92672",
        "fontStyle": "bold"
      }
    },
    {
      "name": "XML Attribute Names",
      "scope": "entity.other.attribute-name.xml",
      "settings": {
        "foreground": "#A6E22E"
      }
    },
    {
      "name": "XML Attribute Values",
      "scope": "string.quoted.double.xml",
      "settings": {
        "foreground": "#E6DB74"
      }
    },
    {
      "name": "KBEngine Numbers",
      "scope": ["constant.numeric.xml", "support.type.numeric.kbengine", "constant.numeric.kbengine"],
      "settings": {
        "foreground": "#AE81FF"
      }
    },
    {
      "name": "KBEngine Constants",
      "scope": ["constant.language.xml", "constant.language.kbengine"],
      "settings": {
        "foreground": "#AE81FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "KBEngine Default Values",
      "scope": "string.unquoted.default.kbengine",
      "settings": {
        "foreground": "#E6DB74"
      }
    },
    {
      "name": "KBEngine Flag Separators",
      "scope": "punctuation.separator.flag.kbengine",
      "settings": {
        "foreground": "#F8F8F0"
      }
    },
    {
      "name": "KBEngine Generic Punctuation",
      "scope": "punctuation.definition.generic.kbengine",
      "settings": {
        "foreground": "#F92672",
        "fontStyle": "bold"
      }
    },
    {
      "name": "KBEngine Generic XML Tags",
      "scope": [
        "entity.name.tag.localname.xml",
        "entity.name.tag.xml"
      ],
      "settings": {
        "foreground": "#F92672",
        "fontStyle": "bold"
      }
    },
    {
      "name": "KBEngine Custom Types",
      "scope": "entity.name.type.custom.kbengine",
      "settings": {
        "foreground": "#A6E22E",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "KBEngine Storage Types",
      "scope": ["storage.type.*.kbengine"],
      "settings": {
        "foreground": "#AE81FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "KBEngine Type Aliases",
      "scope": ["support.class.kbengine", "support.type"],
      "settings": {
        "foreground": "#A6E22E",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "KBEngine Operators",
      "scope": "keyword.operator.xml",
      "settings": {
        "foreground": "#F92672"
      }
    },
    {
      "name": "KBEngine Meta Tags",
      "scope": [
        "meta.block.section.kbengine",
        "meta.block.type-value.kbengine",
        "meta.block.arg-value.kbengine",
        "meta.block.flags-value.kbengine",
        "meta.block.detail-level.kbengine",
        "meta.block.default-value.kbengine",
        "meta.block.numeric-value.kbengine",
        "meta.block.container.kbengine",
        "meta.block.entity-entry.kbengine"
      ],
      "settings": {
        "foreground": "#F8F8F2"
      }
    }
  ]
}
