{
  "scopeName": "source.kbengine-def",
  "patterns": [
    {
      "include": "#root"
    }
  ],
  "repository": {
    "root": {
      "patterns": [
        {
          "include": "#doctype"
        },
        {
          "include": "#comment"
        },
        {
          "include": "#cdata"
        },
        {
          "include": "#section-tag"
        },
        {
          "include": "#type-value-tag"
        },
        {
          "include": "#arg-value-tag"
        },
        {
          "include": "#flags-value-tag"
        },
        {
          "include": "#detail-level-tag"
        },
        {
          "include": "#default-value-tag"
        },
        {
          "include": "#numeric-value-tag"
        },
        {
          "include": "#container-tag"
        },
        {
          "include": "#entity-entry"
        },
        {
          "include": "#generic-tag"
        },
        {
          "include": "#numbers"
        },
        {
          "include": "#constants"
        }
      ]
    },
    "doctype": {
      "begin": "<!(DOCTYPE)",
      "end": ">",
      "captures": {
        "1": {
          "name": "keyword.other.doctype.xml"
        }
      },
      "name": "meta.tag.sgml.doctype.xml"
    },
    "comment": {
      "begin": "<!--",
      "end": "-->",
      "name": "comment.block.xml punctuation.definition.comment.xml"
    },
    "cdata": {
      "begin": "<!\\[CDATA\\[",
      "end": "\\]\\]>",
      "name": "string.unquoted.cdata.xml"
    },
    "section-tag": {
      "name": "meta.block.section.kbengine",
      "begin": "(<)(root|Properties|CellProperties|ClientProperties|BaseMethods|CellMethods|ClientMethods|implementedBy)(?=[\\s>])",
      "end": "(</)(\\2)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.section.kbengine entity.name.tag.xml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.section.kbengine entity.name.tag.xml"
        },
        "3": {
          "name": "punctuation.definition.tag.end.xml"
        }
      },
      "patterns": [
        {
          "include": "#tag-attributes-and-end"
        },
        {
          "include": "#root"
        }
      ]
    },
    "type-value-tag": {
      "name": "meta.block.type-value.kbengine",
      "begin": "(<)(Type)(?=[\\s>])",
      "end": "(</)(\\2)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.scalar.type.kbengine entity.name.tag.xml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.scalar.type.kbengine entity.name.tag.xml"
        },
        "3": {
          "name": "punctuation.definition.tag.end.xml"
        }
      },
      "patterns": [
        {
          "include": "#tag-attributes-and-end"
        },
        {
          "include": "#container-tag"
        },
        {
          "include": "#kbengine-types"
        },
        {
          "match": "[<>]",
          "name": "punctuation.definition.generic.kbengine"
        },
        {
          "match": "\\b[a-zA-Z_][\\w./]*\\b",
          "name": "entity.name.type.custom.kbengine support.class.kbengine support.type"
        }
      ]
    },
    "arg-value-tag": {
      "name": "meta.block.arg-value.kbengine",
      "begin": "(<)(Arg)(?=[\\s>])",
      "end": "(</)(\\2)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.scalar.arg.kbengine entity.name.tag.xml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.scalar.arg.kbengine entity.name.tag.xml"
        },
        "3": {
          "name": "punctuation.definition.tag.end.xml"
        }
      },
      "patterns": [
        {
          "include": "#tag-attributes-and-end"
        },
        {
          "include": "#kbengine-types"
        },
        {
          "match": "[<>]",
          "name": "punctuation.definition.generic.kbengine"
        },
        {
          "match": "\\b[a-zA-Z_][\\w.]*\\b",
          "name": "entity.name.type.custom.kbengine support.class.kbengine support.type"
        }
      ]
    },
    "flags-value-tag": {
      "name": "meta.block.flags-value.kbengine",
      "begin": "(<)(Flags)(?=[\\s>])",
      "end": "(</)(\\2)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.scalar.flags.kbengine entity.name.tag.xml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.scalar.flags.kbengine entity.name.tag.xml"
        },
        "3": {
          "name": "punctuation.definition.tag.end.xml"
        }
      },
      "patterns": [
        {
          "include": "#tag-attributes-and-end"
        },
        {
          "include": "#kbengine-flags"
        },
        {
          "match": "[|,]",
          "name": "punctuation.separator.flag.kbengine"
        }
      ]
    },
    "detail-level-tag": {
      "name": "meta.block.detail-level.kbengine",
      "begin": "(<)(DetailLevel)(?=[\\s>])",
      "end": "(</)(\\2)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.scalar.detail-level.kbengine entity.name.tag.xml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.scalar.detail-level.kbengine entity.name.tag.xml"
        },
        "3": {
          "name": "punctuation.definition.tag.end.xml"
        }
      },
      "patterns": [
        {
          "include": "#tag-attributes-and-end"
        },
        {
          "include": "#kbengine-detail-level"
        }
      ]
    },
    "default-value-tag": {
      "name": "meta.block.default-value.kbengine",
      "begin": "(<)(Default)(?=[\\s>])",
      "end": "(</)(\\2)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.scalar.default.kbengine entity.name.tag.xml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.scalar.default.kbengine entity.name.tag.xml"
        },
        "3": {
          "name": "punctuation.definition.tag.end.xml"
        }
      },
      "patterns": [
        {
          "include": "#tag-attributes-and-end"
        },
        {
          "match": "\"[^\"]*\"",
          "name": "string.quoted.double.kbengine"
        },
        {
          "include": "#constants"
        },
        {
          "include": "#numbers"
        },
        {
          "match": "\\b[^<\\s][^<]*\\b",
          "name": "string.unquoted.default.kbengine"
        }
      ]
    },
    "numeric-value-tag": {
      "name": "meta.block.numeric-value.kbengine",
      "begin": "(<)(Database|Identifier)(?=[\\s>])",
      "end": "(</)(\\2)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.scalar.numeric.kbengine entity.name.tag.xml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.scalar.numeric.kbengine entity.name.tag.xml"
        },
        "3": {
          "name": "punctuation.definition.tag.end.xml"
        }
      },
      "patterns": [
        {
          "include": "#tag-attributes-and-end"
        },
        {
          "include": "#numbers"
        },
        {
          "include": "#constants"
        }
      ]
    },
    "container-tag": {
      "name": "meta.block.container.kbengine",
      "begin": "(<)(FIXED_DICT|TUPLE)(?=[\\s>])",
      "end": "(</)(\\2)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "support.type.container.tag.kbengine entity.name.tag.xml support.type"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "support.type.container.tag.kbengine entity.name.tag.xml support.type"
        },
        "3": {
          "name": "punctuation.definition.tag.end.xml"
        }
      },
      "patterns": [
        {
          "include": "#tag-attributes-and-end"
        },
        {
          "include": "#root"
        }
      ]
    },
    "entity-entry": {
      "name": "meta.block.entity-entry.kbengine",
      "begin": "(<)(?!root\\b|Properties\\b|CellProperties\\b|ClientProperties\\b|BaseMethods\\b|CellMethods\\b|ClientMethods\\b|Type\\b|Flags\\b|Default\\b|Database\\b|Identifier\\b|DetailLevel\\b|Arg\\b|implementedBy\\b|FIXED_DICT\\b|TUPLE\\b)([A-Za-z_][A-Za-z0-9_]*)(?=[\\s>])",
      "end": "(</)(\\2)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.symbol.kbengine entity.name.tag.xml entity.name.function"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.symbol.kbengine entity.name.tag.xml entity.name.function"
        },
        "3": {
          "name": "punctuation.definition.tag.end.xml"
        }
      },
      "patterns": [
        {
          "include": "#tag-attributes-and-end"
        },
        {
          "include": "#root"
        }
      ]
    },
    "generic-tag": {
      "name": "meta.tag.xml",
      "begin": "(<)([A-Za-z0-9_:-]+)",
      "end": "(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.localname.xml"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.end.xml"
        }
      },
      "patterns": [
        {
          "include": "#attribute"
        }
      ]
    },
    "tag-attributes-and-end": {
      "patterns": [
        {
          "include": "#attribute"
        },
        {
          "match": ">",
          "name": "punctuation.definition.tag.end.xml"
        }
      ]
    },
    "attribute": {
      "begin": "\\s([A-Za-z0-9_-]+)\\s*(=)\\s*",
      "end": "(?<=[^\\s=])",
      "beginCaptures": {
        "1": {
          "name": "entity.other.attribute-name.xml"
        },
        "2": {
          "name": "punctuation.separator.key-value.xml"
        }
      },
      "patterns": [
        {
          "include": "#attribute-value"
        }
      ]
    },
    "attribute-value": {
      "name": "string.quoted.double.xml",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "include": "#constants"
        },
        {
          "include": "#kbengine-types"
        },
        {
          "include": "#kbengine-flags"
        }
      ]
    },
    "kbengine-types": {
      "patterns": [
        {
          "match": "\\b(UINT8|UINT16|UINT32|UINT64|INT8|INT16|INT32|INT64)\\b",
          "name": "support.type.primitive.integer.kbengine storage.type.numeric.kbengine"
        },
        {
          "match": "\\b(FLOAT|DOUBLE)\\b",
          "name": "support.type.primitive.float.kbengine storage.type.numeric.kbengine"
        },
        {
          "match": "\\b(BOOL|BOOLEAN)\\b",
          "name": "support.type.primitive.boolean.kbengine storage.type.boolean.kbengine"
        },
        {
          "match": "\\b(STRING)\\b",
          "name": "support.type.primitive.string.kbengine storage.type.string.kbengine"
        },
        {
          "match": "\\b(VECTOR2|VECTOR3|VECTOR4)\\b",
          "name": "support.type.vector.kbengine storage.type.vector.kbengine"
        },
        {
          "match": "\\b(MAILBOX)\\b",
          "name": "support.type.reference.kbengine storage.type.reference.kbengine"
        },
        {
          "match": "\\b(ARRAY|FIXED_DICT|FIXED_ARRAY|TUPLE|MAP)\\b",
          "name": "support.type.container.kbengine storage.type.container.kbengine"
        },
        {
          "match": "\\b(PYTHON|ENTITY)\\b",
          "name": "support.type.python.kbengine storage.type.python.kbengine"
        }
      ]
    },
    "kbengine-flags": {
      "patterns": [
        {
          "match": "\\b(BASE|CLIENT|CELL_PUBLIC|CELL_PRIVATE|CELL_PUBLIC_AND_PRIVATE|BASE_CLIENT|ALL_CLIENTS|OWN_CLIENT)\\b",
          "name": "constant.language.flag.kbengine keyword.declaration.flag.kbengine"
        },
        {
          "match": "\\b(INSTALL_ALWAYS|FLAG_DESTROY|BASE_AND_CLIENT)\\b",
          "name": "constant.other.flag.kbengine"
        }
      ]
    },
    "kbengine-detail-level": {
      "match": "\\b(LOW|MEDIUM|HIGH|CRITICAL)\\b",
      "name": "support.constant.detail-level.kbengine constant.other.level.kbengine"
    },
    "numbers": {
      "match": "\\b([0-9]+\\.?[0-9]*)\\b",
      "name": "constant.numeric.kbengine"
    },
    "constants": {
      "match": "\\b(true|false|TRUE|FALSE|NULL)\\b",
      "name": "constant.language.kbengine"
    }
  }
}
