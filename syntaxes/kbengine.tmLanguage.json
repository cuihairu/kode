{
  "scopeName": "source.kbengine-def",
  "patterns": [
    {
      "include": "#xml-syntax"
    }
  ],
  "repository": {
    "xml-syntax": {
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "include": "#doctype"
        },
        {
          "include": "#tag-opening"
        },
        {
          "include": "#tag-closing"
        },
        {
          "include": "#kbengine-types"
        },
        {
          "include": "#kbengine-flags"
        }
      ]
    },
    "comment": {
      "name": "comment.block.xml",
      "begin": "<!--",
      "end": "-->",
      "patterns": [
        {
          "match": "--",
          "name": "invalid.illegal.bad-comments-or-CDATA.xml"
        }
      ]
    },
    "doctype": {
      "name": "meta.tag.sgml.doctype.xml",
      "begin": "<!DOCTYPE",
      "end": ">",
      "captures": {
        "0": {
          "name": "punctuation.definition.tag.xml"
        }
      }
    },
    "tag-opening": {
      "name": "meta.tag.xml",
      "begin": "(<)([A-Za-z0-9_]+)",
      "end": "(>)",
      "captures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.xml"
        }
      },
      "patterns": [
        {
          "include": "#attribute"
        }
      ]
    },
    "tag-closing": {
      "name": "meta.tag.xml",
      "begin": "(</)([A-Za-z0-9_]+)",
      "end": "(>)",
      "captures": {
        "1": {
          "name": "punctuation.definition.tag.begin.xml"
        },
        "2": {
          "name": "entity.name.tag.xml"
        },
        "3": {
          "name": "punctuation.definition.tag.end.xml"
        }
      }
    },
    "attribute": {
      "name": "entity.other.attribute-name.xml",
      "match": "\\b([A-Za-z0-9_-]+)\\b(?=\\s*\\=)",
      "captures": {
        "1": {
          "name": "entity.other.attribute-name.xml"
        }
      }
    },
    "kbengine-types": {
      "patterns": [
        {
          "match": "\\b(UINT8|UINT16|UINT32|UINT64|INT8|INT16|INT32|INT64)\\b",
          "name": "support.type.primitive.integer.kbengine"
        },
        {
          "match": "\\b(FLOAT|DOUBLE)\\b",
          "name": "support.type.primitive.float.kbengine"
        },
        {
          "match": "\\b(BOOL|STRING)\\b",
          "name": "support.type.primitive.kbengine"
        },
        {
          "match": "\\b(VECTOR2|VECTOR3|VECTOR4)\\b",
          "name": "support.type.vector.kbengine"
        },
        {
          "match": "\\b(MAILBOX)\\b",
          "name": "support.type.reference.kbengine"
        },
        {
          "match": "\\b(ARRAY|FIXED_DICT|TUPLE)\\b",
          "name": "support.type.container.kbengine"
        }
      ]
    },
    "kbengine-flags": {
      "patterns": [
        {
          "match": "\\b(BASE)\\b",
          "name": "constant.language.flag.base.kbengine"
        },
        {
          "match": "\\b(CLIENT)\\b",
          "name": "constant.language.flag.client.kbengine"
        },
        {
          "match": "\\b(CELL_PUBLIC)\\b",
          "name": "constant.language.flag.cell-public.kbengine"
        },
        {
          "match": "\\b(CELL_PRIVATE)\\b",
          "name": "constant.language.flag.cell-private.kbengine"
        },
        {
          "match": "\\b(CELL_PUBLIC_AND_PRIVATE)\\b",
          "name": "constant.language.flag.cell-both.kbengine"
        },
        {
          "match": "\\b(ALL_CLIENTS)\\b",
          "name": "constant.language.flag.all-clients.kbengine"
        },
        {
          "match": "\\b(OWN_CLIENT)\\b",
          "name": "constant.language.flag.own-client.kbengine"
        },
        {
          "match": "\\b(BASE_CLIENT)\\b",
          "name": "constant.language.flag.base-client.kbengine"
        },
        {
          "match": "\\b(LOW|MEDIUM|HIGH|CRITICAL)\\b",
          "name": "constant.language.detail-level.kbengine"
        }
      ]
    }
  }
}
